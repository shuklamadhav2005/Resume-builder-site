# .env.example - Environment Variables Template

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# Database
# ============================================
# Get this from MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.abc123.mongodb.net/resume-builder?retryWrites=true&w=majority

# ============================================
# JWT Authentication
# ============================================
# Use a strong, random string (min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-secret-key-here-min-32-chars

# ============================================
# Admin Initialization
# ============================================
# Email to bootstrap as admin at registration/login
ADMIN_EMAIL=admin@example.com
# Optional: Multiple admins (comma-separated)
# ADMIN_EMAILS=admin1@gmail.com,admin2@gmail.com

# ============================================
# Email Service (SMTP)
# ============================================
# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Gmail: Use App Password (16-char, generated at myaccount.google.com/apppasswords)
# SendGrid: Use "apikey" as SMTP_USER and API key as SMTP_PASS
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=noreply@yourdomain.com

# ============================================
# Optional Cloud Services
# ============================================
# Uncomment if using SendGrid API instead of SMTP
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Uncomment if using AWS S3 for file storage
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1

# ============================================
# Local Development Only
# ============================================
DEBUG=true
LOG_LEVEL=debug
