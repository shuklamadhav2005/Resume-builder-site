<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Resume Builder - Templates</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Fraunces:wght@600;700&display=swap">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    :root {
      --template-bg: #f5f9ff;
      --template-card: #ffffff;
      --template-ink: #0f172a;
      --template-muted: #475569;
    }

    body {
      font-family: "Space Grotesk", system-ui, sans-serif;
      background: radial-gradient(circle at top left, #e6f2ff 0%, #f5f9ff 40%, #ffffff 100%);
      color: var(--template-ink);
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    html {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    html::-webkit-scrollbar,
    body::-webkit-scrollbar {
      width: 0;
      height: 0;
      display: none;
    }

    .templates-page {
      min-height: 100vh;
      padding: 32px 24px 60px;
      position: relative;
      overflow: hidden;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .templates-page::-webkit-scrollbar {
      width: 0;
      height: 0;
      display: none;
    }

    .templates-page::before,
    .templates-page::after {
      content: "";
      position: absolute;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      filter: blur(0px);
      opacity: 0.18;
      z-index: 0;
    }

    .templates-page::before {
      top: -80px;
      left: -60px;
      background: #7dd3fc;
    }

    .templates-page::after {
      bottom: -90px;
      right: -40px;
      background: #bae6fd;
    }

    .templates-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      margin-bottom: 36px;
      position: relative;
      z-index: 1;
    }

    .templates-title h1 {
      font-family: "Fraunces", serif;
      font-size: 36px;
      margin: 0 0 6px;
      color: var(--template-ink);
    }

    .templates-title p {
      margin: 0;
      color: var(--template-muted);
      max-width: 480px;
    }

    .templates-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn-outline-light {
      padding: 10px 16px;
      border: 2px solid #c7dbf9;
      background: #ffffff;
      border-radius: 10px;
      text-decoration: none;
      color: #0f172a;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s;
    }

    .btn-outline-light:hover {
      border-color: #0077cc;
      color: #0077cc;
      transform: translateY(-2px);
      box-shadow: 0 10px 18px rgba(0, 102, 204, 0.12);
    }

    .templates-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
      align-items: stretch;
    }

    .template-card {
      background: var(--template-card);
      border-radius: 16px;
      padding: 16px;
      border: 1px solid #e2ecff;
      box-shadow: 0 8px 18px rgba(15, 23, 42, 0.06);
      display: flex;
      flex-direction: column;
      gap: 12px;
      min-height: 560px;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      position: relative;
    }

    .template-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 18px 36px rgba(15, 23, 42, 0.12);
    }

    .template-badge {
      position: absolute;
      top: 14px;
      right: 14px;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 600;
      padding: 5px 10px;
      border-radius: 999px;
      width: fit-content;
    }

    .template-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .template-title h3 {
      margin: 0;
      font-size: 18px;
    }

    .template-preview {
      background: #f1f6ff;
      border-radius: 12px;
      padding: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 320px;
      overflow: hidden;
    }

    .template-preview > * {
      width: 100%;
      max-width: 100%;
    }

    .resume-sample {
      transform: none;
      transform-origin: top center;
      width: 100%;
      margin: 0 auto;
    }

    .resume-sample p,
    .resume-sample div,
    .resume-sample span {
      word-break: break-word;
    }

    .resume-sample {
      background: #ffffff;
      border: 1px solid #dbe7fb;
      border-radius: 12px;
      padding: 12px;
      box-shadow: 0 10px 20px rgba(15, 23, 42, 0.05);
      display: grid;
      gap: 8px;
      width: 100%;
      overflow: visible;
    }

    .resume-sample-header {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
    }

    .resume-sample-name {
      margin: 0;
      font-size: 15px;
      font-weight: 700;
      color: #0f172a;
    }

    .resume-sample-role {
      margin: 2px 0 0;
      font-size: 12px;
      color: #475569;
    }

    .resume-sample-pill {
      font-size: 11px;
      font-weight: 700;
      color: #1d4ed8;
      background: #dbeafe;
      border-radius: 999px;
      padding: 4px 8px;
      white-space: nowrap;
    }

    .resume-sample-line {
      height: 8px;
      border-radius: 999px;
      background: #dbeafe;
    }

    .resume-sample-line.short {
      width: 72%;
    }

    .resume-sample-line.medium {
      width: 88%;
    }

    .resume-sample-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .resume-sample-block {
      min-height: 34px;
      border-radius: 10px;
      background: #eff6ff;
    }

    .resume-sample-section {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #64748b;
    }

    .preview-header,
    .preview-line,
    .preview-block {
      border-radius: 8px;
    }

    .preview-header {
      height: 48px;
    }

    .preview-line {
      height: 10px;
      opacity: 0.8;
    }

    .preview-block {
      height: 60px;
      opacity: 0.9;
    }

    .template-details {
      color: var(--template-muted);
      font-size: 13px;
      line-height: 1.4;
    }

    .template-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .btn-primary-template,
    .btn-ghost-template {
      border-radius: 10px;
      padding: 8px 12px;
      font-weight: 600;
      font-size: 13px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all 0.3s;
    }

    .btn-primary-template {
      background: #0077cc;
      color: #ffffff;
      border: none;
    }

    .btn-primary-template:hover {
      background: #005fa3;
      transform: translateY(-1px);
    }

    .btn-ghost-template {
      background: transparent;
      border: 1px solid #c7dbf9;
      color: #0f172a;
    }

    .btn-ghost-template:hover {
      border-color: #0077cc;
      color: #0077cc;
    }

    .accent-blue .template-badge {
      background: #dbeafe;
      color: #1d4ed8;
    }

    .accent-emerald .template-badge {
      background: #dcfce7;
      color: #047857;
    }

    .accent-amber .template-badge {
      background: #fef3c7;
      color: #b45309;
    }

    .accent-slate .template-badge {
      background: #e2e8f0;
      color: #334155;
    }

    .accent-rose .template-badge {
      background: #ffe4e6;
      color: #be123c;
    }

    .accent-blue .preview-header { background: linear-gradient(120deg, #3b82f6, #93c5fd); }
    .accent-blue .preview-line { background: #bfdbfe; }
    .accent-blue .preview-block { background: #dbeafe; }
    .accent-blue .resume-sample-pill { background: #dbeafe; color: #1d4ed8; }
    .accent-blue .resume-sample-block { background: #eff6ff; }

    .accent-emerald .preview-header { background: linear-gradient(120deg, #10b981, #6ee7b7); }
    .accent-emerald .preview-line { background: #bbf7d0; }
    .accent-emerald .preview-block { background: #d1fae5; }
    .accent-emerald .resume-sample-pill { background: #dcfce7; color: #047857; }
    .accent-emerald .resume-sample-block { background: #ecfdf5; }

    .accent-amber .preview-header { background: linear-gradient(120deg, #f59e0b, #fcd34d); }
    .accent-amber .preview-line { background: #fde68a; }
    .accent-amber .preview-block { background: #fef3c7; }
    .accent-amber .resume-sample-pill { background: #fef3c7; color: #b45309; }
    .accent-amber .resume-sample-block { background: #fffbeb; }

    .accent-slate .preview-header { background: linear-gradient(120deg, #475569, #94a3b8); }
    .accent-slate .preview-line { background: #cbd5f5; }
    .accent-slate .preview-block { background: #e2e8f0; }
    .accent-slate .resume-sample-pill { background: #e2e8f0; color: #334155; }
    .accent-slate .resume-sample-block { background: #f1f5f9; }

    .accent-rose .preview-header { background: linear-gradient(120deg, #fb7185, #fda4af); }
    .accent-rose .preview-line { background: #fecdd3; }
    .accent-rose .preview-block { background: #ffe4e6; }
    .accent-rose .resume-sample-pill { background: #ffe4e6; color: #be123c; }
    .accent-rose .resume-sample-block { background: #fff1f2; }

    .template-preview-link {
      color: inherit;
      text-decoration: none;
      display: block;
      border-radius: 18px;
    }

    .template-preview-link:hover .template-card {
      transform: translateY(-6px);
    }

    @media (max-width: 720px) {
      .templates-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .template-card {
        min-height: 0;
      }

      .template-preview {
        min-height: 260px;
      }

      .resume-sample {
        transform: none;
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <main class="templates-page">
    <header class="templates-header">
      <div class="templates-title">
        <h1>Template Gallery</h1>
        <p>Pick a layout that matches your style. Each template is ready with a polished hierarchy and spacing.</p>
      </div>
      <div class="templates-actions">
        <a class="btn-outline-light" href="/login">
          <i class="fas fa-arrow-left"></i>
          Back to Login
        </a>
        <a class="btn-outline-light" href="/builder">
          <i class="fas fa-pen-ruler"></i>
          Go to Builder
        </a>
      </div>
    </header>

    <section class="templates-grid">
      <a class="template-preview-link" href="/builder?template=seema">
        <article class="template-card accent-slate">
          <div class="template-badge"><i class="fas fa-star"></i> Classic Split</div>
          <div class="template-title">
            <h3>Modern Style</h3>
            <span>01</span>
          </div>
          <div class="template-preview">
            <div class="resume-sample" style="gap:10px;">
              <div style="display:flex; justify-content:space-between; gap:10px; align-items:flex-start;">
                <div>
                  <p class="resume-sample-name" style="font-size:18px; line-height:0.95; letter-spacing:0.04em;">MODERN<br>TEMPLATE</p>
                  <p class="resume-sample-role" style="font-size:12px;">Clean Creative Layout</p>
                </div>
                <div style="font-size:8px; line-height:1.45; text-align:right; color:#374151;">
                  <div>+123-456-7890</div>
                  <div>hello@reallygreatsite.com</div>
                  <div>123 Anywhere St.</div>
                </div>
              </div>
              <div style="padding:6px 0; text-align:center; background:#f3f4f6; font-size:10px; font-weight:800; letter-spacing:0.14em; color:#111827;">SUMMARY</div>
              <div style="display:grid; grid-template-columns: .9fr 1.1fr; gap:8px;">
                <div style="background:#f4f4f4; padding:8px; min-height:70px; font-size:8px; color:#374151;">
                  <div style="font-size:8px; font-weight:800; margin-bottom:5px;">SKILL</div>
                  Wireframing<br>Prototyping<br>UI Design
                </div>
                <div style="background:#fff; border:1px solid #e5e7eb; padding:8px; min-height:70px; font-size:8px; color:#374151;">
                  <div style="font-size:8px; font-weight:800; margin-bottom:5px;">EXPERIENCE</div>
                  Wardiere Inc.<br>Ingoude Company
                </div>
              </div>
            </div>
          </div>
          <p class="template-details">Classic resume with a left sidebar and clean content column.</p>
          <div class="template-actions">
            <span class="btn-primary-template"><i class="fas fa-check"></i> Use Template</span>
            <span class="btn-ghost-template">Open in Builder</span>
          </div>
        </article>
      </a>

      <a class="template-preview-link" href="/builder?template=lorna">
        <article class="template-card accent-emerald">
          <div class="template-badge"><i class="fas fa-briefcase"></i> Profile Focus</div>
          <div class="template-title">
            <h3>Professional Style</h3>
            <span>02</span>
          </div>
          <div class="template-preview">
            <div class="resume-sample" style="padding:0; overflow:hidden; gap:0;">
              <div style="background:#bdbdbd; padding:8px; display:flex; gap:8px; align-items:center;">
                <div style="font-size:11px; line-height:0.92; font-weight:800; letter-spacing:0.04em; color:#111827;">PROFESSIONAL<br>TEMPLATE<div style="font-size:7px; letter-spacing:0.16em; margin-top:4px; font-weight:500;">PROFILE FOCUS LAYOUT</div></div>
              </div>
              <div style="display:grid; grid-template-columns: .9fr 1.1fr; gap:6px; padding:8px;">
                <div style="background:#f4f4f4; padding:6px; min-height:60px; font-size:8px; color:#374151;">
                  <div style="font-size:8px; font-weight:800; margin-bottom:4px;">PERSONAL PROFILE</div>
                  Experienced software engineer...
                </div>
                <div style="background:#fff; border-left:1px solid #d1d5db; padding-left:6px; min-height:60px; font-size:8px; color:#374151;">
                  <div style="font-size:8px; font-weight:800; margin-bottom:4px;">EDUCATIONAL HISTORY</div>
                  BS Software Engineering<br>ME Software Development
                </div>
              </div>
            </div>
          </div>
          <p class="template-details">Profile-led layout with a photo header and strong content hierarchy.</p>
          <div class="template-actions">
            <span class="btn-primary-template"><i class="fas fa-check"></i> Use Template</span>
            <span class="btn-ghost-template">Open in Builder</span>
          </div>
        </article>
      </a>

      <a class="template-preview-link" href="/builder?template=richard">
        <article class="template-card accent-emerald">
          <div class="template-badge"><i class="fas fa-id-badge"></i> Executive Panel</div>
          <div class="template-title">
            <h3>Executive Style</h3>
            <span>03</span>
          </div>
          <div class="template-preview">
            <div class="resume-sample" style="padding:0; overflow:hidden; gap:0; background:#f8fafc;">
              <div style="display:grid; grid-template-columns:30% 70%; min-height:160px;">
                <div style="background:#153a57; padding:12px 8px; color:#ffffff;">
                  <div style="width:42px; height:42px; border-radius:50%; margin:0 auto 8px; border:2px solid rgba(255,255,255,0.9);"></div>
                  <div style="font-size:8px; font-weight:800; letter-spacing:0.08em; margin-bottom:5px;">CONTACT</div>
                  <div style="height:1px; background:rgba(255,255,255,0.5); margin-bottom:5px;"></div>
                  <div style="font-size:8px; line-height:1.35; color:#dbeafe;">+123-456-7890<br>hello@domain.com</div>
                </div>
                <div style="padding:12px 10px;">
                  <div style="font-size:14px; font-weight:800; line-height:0.95; color:#0f172a;">EXECUTIVE<br>STYLE</div>
                  <div style="font-size:8px; letter-spacing:0.12em; color:#475569; margin-top:4px;">MARKETING MANAGER</div>
                  <div style="margin-top:8px; font-size:8px; font-weight:800; color:#0f172a;">PROFILE</div>
                  <div style="height:1px; background:#94a3b8; margin:4px 0 5px;"></div>
                  <div style="font-size:8px; color:#475569; line-height:1.35;">Structured profile, work experience, and references.</div>
                </div>
              </div>
            </div>
          </div>
          <p class="template-details">Executive resume with dark sidebar, profile headline, and structured right content area.</p>
          <div class="template-actions">
            <span class="btn-primary-template"><i class="fas fa-check"></i> Use Template</span>
            <span class="btn-ghost-template">Open in Builder</span>
          </div>
        </article>
      </a>
    </section>
  </main>
</body>
</html>
