<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Resume Builder - Admin Panel</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Fraunces:wght@600;700&display=swap">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    :root {
      --admin-bg: #f8fafc;
      --admin-surface: #ffffff;
      --admin-ink: #0f172a;
      --admin-muted: #475569;
      --admin-border: #dbe4f0;
      --admin-accent: #0f766e;
      --admin-accent-strong: #115e59;
      --admin-danger: #be123c;
    }

    body {
      margin: 0;
      font-family: "Space Grotesk", system-ui, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(45, 212, 191, 0.12), transparent 32%),
        radial-gradient(circle at top right, rgba(59, 130, 246, 0.12), transparent 28%),
        linear-gradient(180deg, #f8fafc 0%, #eef6f7 100%);
      color: var(--admin-ink);
    }

    .admin-shell {
      min-height: 100vh;
      max-width: 1320px;
      padding: 28px 24px 44px;
      margin: 0 auto;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 700;
      font-size: 20px;
    }

    .brand i {
      color: var(--admin-accent);
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn {
      border: 1px solid var(--admin-border);
      background: var(--admin-surface);
      color: var(--admin-ink);
      border-radius: 12px;
      padding: 10px 14px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.2s ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      border-color: var(--admin-accent);
      color: var(--admin-accent);
    }

    .btn-primary {
      background: var(--admin-accent);
      border-color: var(--admin-accent);
      color: #fff;
    }

    .btn-primary:hover {
      background: var(--admin-accent-strong);
      color: #fff;
    }

    .btn-danger {
      color: var(--admin-danger);
      border-color: #fecdd3;
      background: #fff1f2;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.8fr) minmax(280px, 0.9fr);
      gap: 18px;
      margin-bottom: 22px;
    }

    .panel {
      background: var(--admin-surface);
      border: 1px solid var(--admin-border);
      border-radius: 20px;
      padding: 22px;
      box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08);
    }

    .panel h1,
    .panel h2 {
      margin: 0 0 10px;
    }

    .panel p {
      margin: 0;
      color: var(--admin-muted);
      line-height: 1.6;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin: 20px 0 22px;
    }

    .stat-card {
      background: var(--admin-surface);
      border: 1px solid var(--admin-border);
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    }

    .stat-card .label {
      color: var(--admin-muted);
      font-size: 13px;
      margin-bottom: 8px;
    }

    .stat-card .value {
      font-size: 30px;
      font-weight: 700;
    }

    .content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1.25fr);
      gap: 18px;
      align-items: start;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      margin-bottom: 14px;
      flex-wrap: wrap;
    }

    .table-wrap {
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 620px;
    }

    th,
    td {
      text-align: left;
      padding: 12px 10px;
      border-bottom: 1px solid var(--admin-border);
      font-size: 14px;
      vertical-align: top;
    }

    th {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--admin-muted);
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      background: #e8f9f6;
      color: var(--admin-accent-strong);
      font-size: 12px;
      font-weight: 700;
    }

    .pill.admin {
      background: #eff6ff;
      color: #1d4ed8;
    }

    .pill.user {
      background: #f1f5f9;
      color: #334155;
    }

    .table-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .role-switch {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      user-select: none;
    }

    .role-switch input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .role-switch-track {
      width: 56px;
      height: 32px;
      border-radius: 999px;
      background: #e2e8f0;
      border: 1px solid #cbd5e1;
      padding: 2px;
      display: inline-flex;
      align-items: center;
      transition: all 0.2s ease;
      position: relative;
      flex: 0 0 auto;
    }

    .role-switch-thumb {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: #ffffff;
      box-shadow: 0 6px 12px rgba(15, 23, 42, 0.16);
      transform: translateX(0);
      transition: transform 0.2s ease, background 0.2s ease;
    }

    .role-switch input:checked + .role-switch-track {
      background: linear-gradient(135deg, #14b8a6, #0f766e);
      border-color: #0f766e;
    }

    .role-switch input:checked + .role-switch-track .role-switch-thumb {
      transform: translateX(24px);
    }

    .role-switch-text {
      font-size: 12px;
      font-weight: 700;
      color: var(--admin-muted);
      min-width: 42px;
    }

    .empty-state {
      padding: 22px;
      text-align: center;
      color: var(--admin-muted);
      border: 1px dashed var(--admin-border);
      border-radius: 16px;
    }

    @media (max-width: 1080px) {
      .hero,
      .content-grid,
      .stat-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 920px) {
      .admin-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .header-actions {
        width: 100%;
      }

      .header-actions .btn {
        flex: 1 1 160px;
        justify-content: center;
      }

      .hero,
      .content-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .admin-shell {
        padding: 20px 14px 36px;
      }

      .stat-grid {
        grid-template-columns: 1fr;
      }

      .panel {
        padding: 18px;
      }

      .table-wrap {
        overflow: visible;
      }

      table,
      thead,
      tbody,
      tr,
      th,
      td {
        display: block;
        width: 100%;
        min-width: 0;
      }

      thead {
        display: none;
      }

      tbody {
        display: grid;
        gap: 12px;
      }

      tr {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid var(--admin-border);
        border-radius: 18px;
        padding: 14px 14px 10px;
        box-shadow: 0 12px 24px rgba(15, 23, 42, 0.06);
      }

      td {
        border-bottom: none;
        padding: 10px 0;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
      }

      td::before {
        content: attr(data-label);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--admin-muted);
        flex: 0 0 96px;
      }

      td > *:not(.table-actions):not(.role-switch) {
        text-align: right;
      }

      .table-actions {
        width: 100%;
        justify-content: flex-end;
      }

      .role-switch {
        margin-left: auto;
      }
    }
  </style>
</head>
<body>
  <main class="admin-shell">
    <header class="admin-header">
      <div class="brand">
        <i class="fas fa-shield-alt"></i>
        Resume Builder Admin
      </div>
      <div class="header-actions">
        <a class="btn" href="/dashboard"><i class="fas fa-arrow-left"></i> Dashboard</a>
        <a class="btn btn-primary" href="/builder"><i class="fas fa-pen-nib"></i> Builder</a>
        <button class="btn" id="refreshBtn" type="button"><i class="fas fa-rotate"></i> Refresh</button>
        <button class="btn btn-danger" id="logoutBtn" type="button"><i class="fas fa-right-from-bracket"></i> Logout</button>
      </div>
    </header>

    <section class="hero">
      <div class="panel">
        <h1>Admin control center</h1>
        <p>Manage users, change roles, and remove resumes from one place. Access is restricted to accounts with the <strong>admin</strong> role.</p>
      </div>
      <div class="panel">
        <h2>Current access</h2>
        <p id="adminIdentity">Loading profile...</p>
      </div>
    </section>

    <section class="stat-grid" aria-label="Admin statistics">
      <article class="stat-card"><div class="label">Users</div><div class="value" id="statUsers">-</div></article>
      <article class="stat-card"><div class="label">Admins</div><div class="value" id="statAdmins">-</div></article>
      <article class="stat-card"><div class="label">Resumes</div><div class="value" id="statResumes">-</div></article>
      <article class="stat-card"><div class="label">Downloads</div><div class="value" id="statDownloads">-</div></article>
    </section>

    <section class="content-grid">
      <div class="panel">
        <div class="section-header">
          <div>
            <h2>Users</h2>
            <p>Promote or remove users. Admins can manage their own account, but cannot delete themselves here.</p>
          </div>
        </div>
        <div id="usersEmpty" class="empty-state" hidden>No users loaded.</div>
        <div class="table-wrap">
          <table aria-label="Users table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="usersTableBody"></tbody>
          </table>
        </div>
      </div>

      <div class="panel">
        <div class="section-header">
          <div>
            <h2>Resumes</h2>
            <p>Review all resume records in the system and remove entries if needed.</p>
          </div>
        </div>
        <div id="resumesEmpty" class="empty-state" hidden>No resumes loaded.</div>
        <div class="table-wrap">
          <table aria-label="Resumes table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Owner</th>
                <th>Downloads</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="resumesTableBody"></tbody>
          </table>
        </div>
      </div>
    </section>
  </main>

  <script src="/js/toast.js"></script>
  <script src="/js/admin.js"></script>
</body>
</html>