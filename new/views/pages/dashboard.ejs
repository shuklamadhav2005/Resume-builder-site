<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Resume Builder - Dashboard</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Fraunces:wght@600;700&display=swap">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    :root {
      --dash-bg: #f4f9ff;
      --dash-card: #ffffff;
      --dash-ink: #0f172a;
      --dash-muted: #475569;
      --dash-border: #dbeafe;
      --dash-accent: #0066cc;
    }

    html {
      scrollbar-color: #a0d4ff rgba(244, 249, 255, 0.5);
      scrollbar-width: thin;
    }

    html,
    body {
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    html::-webkit-scrollbar,
    body::-webkit-scrollbar {
      width: 0;
      height: 0;
      display: none;
    }

    /* Professional Webkit scrollbar styling for light mode */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: rgba(240, 248, 255, 0.3);
      border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb {
      background: linear-gradient(to bottom, #7ecbff, #5bb8ff);
      border-radius: 10px;
      min-height: 30px;
      box-shadow: inset 0 0 4px rgba(0, 0, 0, 0.05);
      transition: all 0.3s ease;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: linear-gradient(to bottom, #5bb8ff, #38a5ff);
      box-shadow: inset 0 0 4px rgba(0, 0, 0, 0.1);
    }

    ::-webkit-scrollbar-thumb:active {
      background: linear-gradient(to bottom, #38a5ff, #2695e8);
      box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.15);
    }

    body {
      font-family: "Space Grotesk", system-ui, sans-serif;
      background: radial-gradient(circle at top, #e0f2ff 0%, #f4f9ff 40%, #ffffff 100%);
      color: var(--dash-ink);
    }

    .dashboard-page {
      min-height: 100vh;
      padding: 28px 24px 60px;
      position: relative;
      overflow: hidden;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .dashboard-page::-webkit-scrollbar {
      width: 0;
      height: 0;
      display: none;
    }

    .dashboard-page::before,
    .dashboard-page::after {
      content: "";
      position: absolute;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      opacity: 0.16;
      z-index: 0;
    }

    .dashboard-page::before {
      top: -120px;
      right: -140px;
      background: #bae6fd;
    }

    .dashboard-page::after {
      bottom: -140px;
      left: -120px;
      background: #93c5fd;
    }

    .dashboard-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      position: relative;
      z-index: 1;
      margin-bottom: 28px;
      flex-wrap: wrap;
    }

    .brand-block {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 700;
      font-size: 20px;
      color: var(--dash-ink);
    }

    .brand-block i {
      color: var(--dash-accent);
      font-size: 24px;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .mobile-nav {
      display: none;
      position: relative;
    }

    .mobile-menu-toggle {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      border: 2px solid var(--dash-border);
      background: #ffffff;
      color: var(--dash-ink);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.25s ease;
    }

    .mobile-menu-toggle:hover {
      border-color: var(--dash-accent);
      color: var(--dash-accent);
      transform: translateY(-1px);
    }

    .mobile-nav-dropdown {
      position: absolute;
      right: 0;
      top: calc(100% + 10px);
      min-width: 220px;
      padding: 10px;
      border-radius: 14px;
      border: 1px solid var(--dash-border);
      background: #ffffff;
      box-shadow: 0 18px 28px rgba(15, 23, 42, 0.14);
      display: none;
      z-index: 30;
    }

    .mobile-nav-dropdown.active {
      display: grid;
      gap: 8px;
    }

    .mobile-nav-item {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      width: 100%;
      text-decoration: none;
      color: var(--dash-ink);
      border: 1px solid #cfe2ff;
      background: #f8fbff;
      padding: 10px 12px;
      border-radius: 10px;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .mobile-nav-item:hover {
      border-color: var(--dash-accent);
      color: var(--dash-accent);
      background: #eff6ff;
    }

    .mobile-nav-item-danger {
      color: #be123c;
      border-color: #fecdd3;
      background: #fff1f2;
    }

    .mobile-nav-item-danger:hover {
      color: #be123c;
      border-color: #fb7185;
      background: #ffe4e6;
    }

    .btn-create {
      background: var(--dash-accent);
      color: #ffffff;
      border-radius: 10px;
      padding: 10px 16px;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s;
    }

    .btn-create:hover {
      background: #0052a3;
      transform: translateY(-2px);
      box-shadow: 0 10px 18px rgba(0, 102, 204, 0.18);
    }

    .btn-ghost {
      background: transparent;
      border: 2px solid var(--dash-border);
      color: var(--dash-ink);
      border-radius: 10px;
      padding: 10px 14px;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s;
    }

    .btn-ghost:hover {
      border-color: var(--dash-accent);
      color: var(--dash-accent);
      transform: translateY(-2px);
    }

    .theme-toggle {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: 2px solid var(--dash-border);
      background: #ffffff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s;
    }

    .theme-toggle:hover {
      border-color: var(--dash-accent);
      color: var(--dash-accent);
    }

    .user-menu {
      position: relative;
    }

    .user-avatar {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: #e0f2fe;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #0f172a;
      cursor: pointer;
    }

    .user-dropdown {
      position: absolute;
      top: 50px;
      right: 0;
      background: #ffffff;
      border-radius: 12px;
      border: 1px solid var(--dash-border);
      box-shadow: 0 18px 28px rgba(15, 23, 42, 0.12);
      padding: 12px;
      min-width: 180px;
      display: none;
      z-index: 10;
    }

    .user-dropdown.active {
      display: block;
    }

    .user-dropdown a {
      display: flex;
      gap: 10px;
      padding: 8px 10px;
      color: var(--dash-ink);
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
    }

    .user-dropdown a:hover {
      background: #eff6ff;
      color: var(--dash-accent);
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: 24px;
      position: relative;
      z-index: 1;
    }

    .panel {
      background: var(--dash-card);
      border-radius: 18px;
      border: 1px solid var(--dash-border);
      padding: 22px;
      box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    .panel-title {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .panel-title h2 {
      margin: 0;
      font-size: 20px;
    }

    .resume-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 12px;
    }

    .resume-card {
      border-radius: 18px;
      border: 1px solid #d7e8ff;
      padding: 11px;
      display: grid;
      gap: 9px;
      background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
      overflow: hidden;
    }

    .resume-card:hover {
      transform: translateY(-3px);
      border-color: #bcd8ff;
      box-shadow: 0 16px 30px rgba(15, 23, 42, 0.1);
    }

    .resume-preview-tile {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 12px;
      overflow: hidden;
      background: linear-gradient(135deg, #e0f2ff 0%, #dbeafe 45%, #bfdbfe 100%);
      border: 1px solid #cfe2ff;
    }

    .resume-preview-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .resume-preview-fallback {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      font-weight: 700;
      color: #ffffff;
      background: linear-gradient(135deg, #0066cc, #7c3aed);
    }

    .resume-preview-overlay {
      position: absolute;
      left: 8px;
      right: 8px;
      bottom: 8px;
      padding: 6px 8px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.62);
      backdrop-filter: blur(10px);
      color: #ffffff;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.02em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .resume-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .resume-card h3 {
      margin: 0;
      font-size: 15px;
      line-height: 1.2;
    }

    .resume-card-id {
      color: var(--dash-muted);
      font-size: 11px;
      font-weight: 600;
      white-space: nowrap;
    }

    .resume-card-subtitle {
      margin: -4px 0 0;
      color: var(--dash-muted);
      font-size: 12px;
      font-weight: 500;
    }

    .resume-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 11px;
      color: var(--dash-muted);
      padding-top: 2px;
    }

    .resume-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .btn-action {
      border-radius: 9px;
      padding: 6px 9px;
      border: 1px solid #c7dbf9;
      background: #ffffff;
      color: var(--dash-ink);
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      transition: all 0.3s;
    }

    .btn-action:hover {
      border-color: var(--dash-accent);
      color: var(--dash-accent);
      transform: translateY(-1px);
    }

    .btn-danger {
      border-color: #fecdd3;
      color: #be123c;
      background: #fff1f2;
    }

    .btn-danger:hover {
      border-color: #fb7185;
      color: #be123c;
    }

    .account-card {
      display: grid;
      gap: 18px;
    }

    .account-row {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .account-avatar {
      width: 54px;
      height: 54px;
      border-radius: 16px;
      background: #dbeafe;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      font-weight: 700;
    }

    .account-info h4 {
      margin: 0 0 4px;
      font-size: 16px;
    }

    .account-info p {
      margin: 0;
      color: var(--dash-muted);
      font-size: 14px;
    }

    .stats-grid {
      display: grid;
      gap: 12px;
    }

    .stat-card {
      padding: 14px;
      border-radius: 14px;
      background: #f1f5ff;
      border: 1px solid #e2ecff;
    }

    .stat-card h3 {
      margin: 0 0 4px;
      font-size: 16px;
    }

    .stat-card p {
      margin: 0;
      color: var(--dash-muted);
      font-size: 13px;
    }

    .empty-state {
      text-align: center;
      padding: 28px;
      border: 1px dashed #c7dbf9;
      border-radius: 16px;
      color: var(--dash-muted);
    }

    @media (max-width: 980px) {
      .dashboard-grid {
        grid-template-columns: 1fr;
      }

      .dashboard-grid > aside.panel {
        order: 1;
      }

      .dashboard-grid > .panel:first-child {
        order: 2;
      }
    }

    @media (max-width: 768px) {
      .dashboard-header {
        align-items: flex-start;
      }

      .header-actions {
        display: none;
      }

      .mobile-nav {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        width: 100%;
        margin-top: 6px;
      }

      .mobile-nav-dropdown {
        position: static;
        width: 100%;
        max-width: 280px;
        margin-top: 10px;
        box-shadow: 0 10px 20px rgba(15, 23, 42, 0.12);
      }

      .resume-list {
        grid-template-columns: 1fr;
      }
    }

    /* Dark Mode Styles */
    html.dark-mode {
      --dash-bg: #0f172a;
      --dash-card: #1e293b;
      --dash-ink: #f1f5f9;
      --dash-muted: #94a3b8;
      --dash-border: #334155;
      --dash-accent: #3b82f6;
      scrollbar-color: #3b82f6 #0f172a;
    }

    /* Professional Webkit scrollbar styling for dark mode */
    html.dark-mode ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    html.dark-mode ::-webkit-scrollbar-track {
      background: rgba(15, 23, 42, 0.4);
      border-radius: 10px;
    }

    html.dark-mode ::-webkit-scrollbar-thumb {
      background: linear-gradient(to bottom, #7ecbff, #5bb8ff);
      border-radius: 10px;
      min-height: 30px;
      box-shadow: inset 0 0 4px rgba(255, 255, 255, 0.1);
      transition: all 0.3s ease;
    }

    html.dark-mode ::-webkit-scrollbar-thumb:hover {
      background: linear-gradient(to bottom, #5bb8ff, #38a5ff);
      box-shadow: inset 0 0 4px rgba(255, 255, 255, 0.2);
    }

    html.dark-mode ::-webkit-scrollbar-thumb:active {
      background: linear-gradient(to bottom, #38a5ff, #2695e8);
      box-shadow: inset 0 0 5px rgba(255, 255, 255, 0.3);
    }

    html.dark-mode body {
      background: radial-gradient(circle at top, #1e293b 0%, #0f172a 40%, #020617 100%);
      color: var(--dash-ink);
    }

    html.dark-mode .dashboard-page::before {
      background: #1e3a5f;
    }

    html.dark-mode .dashboard-page::after {
      background: #1e3a5f;
    }

    html.dark-mode .brand-block {
      color: var(--dash-ink);
    }

    html.dark-mode .brand-block i {
      color: var(--dash-accent);
    }

    html.dark-mode .btn-create {
      background: var(--dash-accent);
      color: #ffffff;
    }

    html.dark-mode .btn-create:hover {
      background: #2563eb;
      box-shadow: 0 10px 18px rgba(59, 130, 246, 0.25);
    }

    html.dark-mode .btn-ghost {
      border-color: var(--dash-border);
      color: var(--dash-ink);
      background: transparent;
    }

    html.dark-mode .btn-ghost:hover {
      border-color: var(--dash-accent);
      color: var(--dash-accent);
      background: rgba(59, 130, 246, 0.1);
    }

    html.dark-mode .theme-toggle {
      background: var(--dash-card);
      border-color: var(--dash-border);
      color: var(--dash-ink);
    }

    html.dark-mode .theme-toggle:hover {
      border-color: var(--dash-accent);
      color: var(--dash-accent);
    }

    html.dark-mode .mobile-menu-toggle {
      background: var(--dash-card);
      border-color: var(--dash-border);
      color: var(--dash-ink);
    }

    html.dark-mode .mobile-menu-toggle:hover {
      border-color: var(--dash-accent);
      color: var(--dash-accent);
      background: rgba(59, 130, 246, 0.08);
    }

    html.dark-mode .mobile-nav-dropdown {
      background: var(--dash-card);
      border-color: var(--dash-border);
      box-shadow: 0 18px 28px rgba(0, 0, 0, 0.4);
    }

    html.dark-mode .mobile-nav-item {
      color: var(--dash-ink);
      border-color: var(--dash-border);
      background: #0f1d2e;
    }

    html.dark-mode .mobile-nav-item:hover {
      color: var(--dash-accent);
      border-color: var(--dash-accent);
      background: rgba(59, 130, 246, 0.1);
    }

    html.dark-mode .mobile-nav-item-danger {
      color: #fda4af;
      border-color: #881337;
      background: #4c0519;
    }

    html.dark-mode .mobile-nav-item-danger:hover {
      color: #fda4af;
      border-color: #be123c;
      background: #7f1d1d;
    }

    html.dark-mode .user-avatar {
      background: #1e3a5f;
      color: #60a5fa;
    }

    html.dark-mode .user-dropdown {
      background: var(--dash-card);
      border-color: var(--dash-border);
      box-shadow: 0 18px 28px rgba(0, 0, 0, 0.4);
    }

    html.dark-mode .user-dropdown a {
      color: var(--dash-ink);
    }

    html.dark-mode .user-dropdown a:hover {
      background: #334155;
      color: var(--dash-accent);
    }

    html.dark-mode .panel {
      background: var(--dash-card);
      border-color: var(--dash-border);
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
    }

    html.dark-mode .panel-title h2 {
      color: var(--dash-ink);
    }

    html.dark-mode .panel-title span {
      color: var(--dash-muted);
    }

    html.dark-mode .resume-card {
      background: linear-gradient(180deg, #0f1d2e 0%, #111f33 100%);
      border-color: #24354d;
    }

    html.dark-mode .resume-card:hover {
      border-color: #3b82f6;
      box-shadow: 0 16px 30px rgba(0, 0, 0, 0.34);
    }

    html.dark-mode .resume-preview-tile {
      background: linear-gradient(135deg, #1e3a5f 0%, #1d4ed8 45%, #7c3aed 100%);
      border-color: rgba(148, 163, 184, 0.18);
    }

    html.dark-mode .resume-preview-overlay {
      background: rgba(15, 23, 42, 0.72);
    }

    html.dark-mode .resume-card h3 {
      color: var(--dash-ink);
    }

    html.dark-mode .resume-card-id,
    html.dark-mode .resume-card-header span {
      color: var(--dash-muted);
    }

    html.dark-mode .resume-card-subtitle {
      color: #cbd5e1;
    }

    html.dark-mode .resume-meta {
      color: var(--dash-muted);
    }

    html.dark-mode .btn-action {
      background: var(--dash-card);
      border-color: var(--dash-border);
      color: var(--dash-ink);
    }

    html.dark-mode .btn-action:hover {
      border-color: var(--dash-accent);
      color: var(--dash-accent);
      background: rgba(59, 130, 246, 0.1);
    }

    html.dark-mode .btn-danger {
      background: #4c0519;
      border-color: #881337;
      color: #fda4af;
    }

    html.dark-mode .btn-danger:hover {
      border-color: #be123c;
      color: #fda4af;
      background: #881337;
    }

    html.dark-mode .account-avatar {
      background: #1e3a5f;
      color: #60a5fa;
    }

    html.dark-mode .account-info h4 {
      color: var(--dash-ink);
    }

    html.dark-mode .account-info p {
      color: var(--dash-muted);
    }

    html.dark-mode .stat-card {
      background: #0f1d2e;
      border-color: var(--dash-border);
    }

    html.dark-mode .stat-card h3 {
      color: var(--dash-ink);
    }

    html.dark-mode .stat-card p {
      color: var(--dash-muted);
    }

    html.dark-mode .empty-state {
      border-color: var(--dash-border);
      color: var(--dash-muted);
    }
  </style>
</head>
<body>
  <main class="dashboard-page">
    <header class="dashboard-header">
      <div class="brand-block">
        <i class="fas fa-file-alt"></i>
        Resume Builder Dashboard
      </div>
      <div class="header-actions">
        <a class="btn-create" href="/builder">
          <i class="fas fa-plus"></i>
          Create Resume
        </a>
        <a class="btn-ghost" href="/templates">
          <i class="fas fa-layer-group"></i>
          Templates
        </a>
        <button class="btn-ghost" id="logoutBtnNav" title="Logout">
          <i class="fas fa-sign-out-alt"></i>
          Logout
        </button>
        <button class="theme-toggle" id="themeToggle" title="Toggle theme">
          <i class="fas fa-moon"></i>
        </button>
        <div class="user-menu">
          <div class="user-avatar" id="userAvatar">U</div>
          
        </div>
      </div>
      <div class="mobile-nav">
        <button class="mobile-menu-toggle" id="mobileMenuToggle" title="Open menu">
          <i class="fas fa-bars"></i>
        </button>
        <div class="mobile-nav-dropdown" id="mobileNavDropdown">
          <a class="mobile-nav-item" href="/builder">
            <i class="fas fa-plus"></i>
            Create Resume
          </a>
          <a class="mobile-nav-item" href="/templates">
            <i class="fas fa-layer-group"></i>
            Templates
          </a>
          <button class="mobile-nav-item" id="mobileThemeToggle" type="button">
            <i class="fas fa-moon"></i>
            Toggle Theme
          </button>
          <button class="mobile-nav-item mobile-nav-item-danger" id="mobileLogoutBtn" type="button">
            <i class="fas fa-sign-out-alt"></i>
            Logout
          </button>
        </div>
      </div>
    </header>

    <section class="dashboard-grid">
      <div class="panel">
        <div class="panel-title">
          <h2>Your Resumes</h2>
          <span id="resumeCount">0 total</span>
        </div>
        <div class="resume-list" id="resumeList"></div>
        <div class="empty-state" id="emptyState" style="display:none;">
          No resumes yet. Create your first resume to get started.
        </div>
      </div>

      <aside class="panel">
        <div class="account-card">
          <div class="panel-title">
            <h2>Account</h2>
          </div>
          <div class="account-row">
            <div class="account-avatar" id="accountAvatar">U</div>
            <div class="account-info">
              <h4 id="accountName">User</h4>
              <p id="accountEmail">user@example.com</p>
            </div>
          </div>
          <div class="stats-grid">
            <div class="stat-card">
              <h3 id="statsResumes">0</h3>
              <p>Total resumes</p>
            </div>
            <div class="stat-card">
              <h3 id="statsDownloads">0</h3>
              <p>Total downloads</p>
            </div>
            <div class="stat-card">
              <h3 id="statsLastEdited">-</h3>
              <p>Last edited</p>
            </div>
          </div>
        </div>
      </aside>
    </section>
  </main>

  <script src="/js/toast.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>